# ============================================
# Worklight Monorepo - .gitignore
# ============================================

# ---------- Dependencies ----------
node_modules/
.pnp/
.pnp.js

# ---------- Environment / Secrets ----------
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production

# ---------- OS Files ----------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.windsurf/

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ---------- Root Build / Cache ----------
*.tsbuildinfo
.nx/
.nx/cache/

# ---------- TypeScript Build Artifacts ----------
*.d.ts
*.d.ts.map
*.js.map

# ---------- Package Locks (uncomment if not committing lock files) ----------
# pnpm-lock.yaml
# package-lock.json
# yarn.lock

# ============================================
# Shared Libraries (libs/) - Build Outputs
# ============================================
libs/*/dist/
libs/*/build/
libs/*/*.tsbuildinfo
libs/*/tsconfig.tsbuildinfo

# ============================================
# Frontend (Next.js) - apps/web/
# ============================================
apps/web/.next/
apps/web/out/
apps/web/build/
apps/web/.env*.local
apps/web/coverage/
apps/web/.turbo/

# ============================================
# Landing Page (Vite) - apps/landing/
# ============================================
apps/landing/dist/
apps/landing/.vite/
apps/landing/coverage/

# ============================================
# Core API (Express) - apps/api/
# ============================================
apps/api/build/
apps/api/dist/
apps/api/uploads/
apps/api/coverage/
apps/api/*.log

# ============================================
# Worker Service - apps/worker/
# ============================================
apps/worker/dist/
apps/worker/coverage/

# ============================================
# Scheduler Service - apps/scheduler/
# ============================================
apps/scheduler/dist/
apps/scheduler/coverage/

# ============================================
# Docker
# ============================================
docker/volumes/
*.pid

# ============================================
# Testing
# ============================================
coverage/
playwright-report/
test-results/
.nyc_output/
*.lcov

# ============================================
# Misc
# ============================================
*.tgz
*.gz
*.zip
.cache/
.temp/
.tmp/

# ============================================
# Nx / Monorepo
# ============================================
.nx/
.nx/cache/
.turbo/

master.envapps/ai-runtime/dist/
