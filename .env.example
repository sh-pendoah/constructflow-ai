# MongoDB Configuration
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB=docflow-360
MONGO_PORT=27017

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Core API Configuration
NODE_ENV=staging
CORE_API_PORT=3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
FRONTEND_PORT=3001

# Landing Page Configuration
LANDING_PAGE_PORT=3002

# File Upload Configuration (Core API)
MAX_FILE_SIZE=50mb
UPLOAD_DIR=/uploads

# Email Configuration (Core API)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=password

# AI/LangChain Configuration (Core API)
OPENAI_API_KEY=your_openai_api_key_here
LANGCHAIN_API_KEY=your_langchain_key_here

# Azure Blob Storage (Core API)
AZURE_STORAGE_ACCOUNT=your_account
AZURE_STORAGE_KEY=your_key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=docflow-360

# Azure Form Recognizer (Core API) - Pre-built Models for Invoices/Receipts
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_API_KEY=your_key

# Azure Document Intelligence (Core API) - General OCR
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=your_key

# Azure OpenAI (Core API)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key
# Recommended models: gpt-4.1 (latest), gpt-4o (optimized), gpt-4-turbo, gpt-4
# API version: 2025-03-01-preview (latest as of Feb 2026)
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# OCR and LLM Provider Selection
# OCR_PROVIDER options: azure-form-recognizer, azure-document-intelligence, google-vision, aws-textract, mindee, mock
# Recommended: azure-form-recognizer (best for invoices/receipts)
OCR_PROVIDER=azure-form-recognizer
LLM_PROVIDER=azure-openai

# JWT Secret (Core API)
JWT_SECRET=your_jwt_secret_here

# Google Auth (Core API - optional)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# Logging
LOG_LEVEL=info

