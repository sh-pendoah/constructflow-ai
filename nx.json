{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "nx/presets/npm.json",
  "affected": {
    "defaultBase": "main"
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/**/*",
        "!{projectRoot}/node_modules/**/*",
        "!{projectRoot}/dist/**/*",
        "!{projectRoot}/.next/**/*",
        "!{projectRoot}/build/**/*"
      ],
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/build",
        "{projectRoot}/.next"
      ]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{projectRoot}/**/*.js",
        "{projectRoot}/**/*.jsx",
        "{projectRoot}/.eslintrc.json",
        "{projectRoot}/.eslintrc.js"
      ]
    },
    "test": {
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{projectRoot}/**/*.spec.ts",
        "{projectRoot}/**/*.test.ts"
      ]
    },
    "dev": {
      "cache": false
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.ts",
      "!{projectRoot}/.eslintrc.json"
    ]
  },
  "plugins": [
    {
      "plugin": "@nx/js",
      "options": {
        "buildTargetName": "build",
        "devTargetName": "dev",
        "testTargetName": "test"
      }
    }
  ],
  "release": {
    "version": {
      "conventionalCommits": true
    }
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test"]
      }
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  }
}
