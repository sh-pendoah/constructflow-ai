{
  "name": "worklighter-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Worklighter Construction Operations Automation Engine - Nx-orchestrated monorepo",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "install:all": "pnpm install",
    "dev": "nx run-many --target=dev --all --parallel",
    "dev:api": "nx run api:dev",
    "dev:web": "nx run web:dev",
    "dev:ai-runtime": "nx run ai-runtime:dev",
    "dev:worker": "nx run worker:dev",
    "dev:scheduler": "nx run scheduler:dev",
    "build": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "build:api": "nx run api:build",
    "build:web": "nx run web:build",
    "build:ai-runtime": "nx run ai-runtime:build",
    "build:worker": "nx run worker:build",
    "build:scheduler": "nx run scheduler:build",
    "lint": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint",
    "test": "nx run-many --target=test --all",
    "test:affected": "nx affected --target=test",
    "test:e2e": "playwright test",
    "infra:up": "docker-compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker-compose -f docker-compose.infra.yml down",
    "infra:logs": "docker-compose -f docker-compose.infra.yml logs -f",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "graph": "nx graph",
    "clean": "nx reset && rm -rf node_modules apps/*/node_modules libs/*/node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "nx": "^20.3.0",
    "@nx/workspace": "^20.3.0",
    "@nx/js": "^20.3.0",
    "@nx/node": "^20.3.0",
    "typescript": "^5.7.2"
  }
}
