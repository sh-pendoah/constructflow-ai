{
  "name": "constructflow-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "ConstructFlow AI construction project management platform - Nx-orchestrated monorepo",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "install:all": "pnpm install",
    "dev": "docker-compose up",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "dev:scheduler": "pnpm --filter scheduler dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:worker": "pnpm --filter worker build",
    "build:scheduler": "pnpm --filter scheduler build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "infra:up": "docker-compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker-compose -f docker-compose.infra.yml down",
    "infra:logs": "docker-compose -f docker-compose.infra.yml logs -f",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  }
}
