# Frontend Environment Variables
# These are used at build time and runtime

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=30000

# Application Configuration
NEXT_PUBLIC_APP_NAME=Worklighter
NEXT_PUBLIC_APP_ENV=development

# Authentication
NEXT_PUBLIC_AUTH_ENABLED=true
JWT_SECRET=your-secret-key-change-in-production

# Feature Flags
NEXT_PUBLIC_ENABLE_OCR=true
NEXT_PUBLIC_ENABLE_EMAIL_INGESTION=true
NEXT_PUBLIC_ENABLE_COMPLIANCE_ALERTS=true

# File Upload
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.heic

# UI Configuration
NEXT_PUBLIC_ITEMS_PER_PAGE=25
NEXT_PUBLIC_ENABLE_KEYBOARD_SHORTCUTS=true

# Monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_ID=
