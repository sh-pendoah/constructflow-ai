{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api",
  "projectType": "application",
  "tags": ["scope:backend", "type:api"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc",
        "cwd": "apps/api"
      },
      "outputs": ["{projectRoot}/build"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon index.ts",
        "cwd": "apps/api"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node build/index.js",
        "cwd": "apps/api"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --ignore-pattern node_modules --ignore-pattern build",
        "cwd": "apps/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No tests configured yet' && exit 0",
        "cwd": "apps/api"
      }
    }
  }
}
