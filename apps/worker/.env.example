# Worker Service Environment Variables

# MongoDB
MONGO_URI=mongodb://admin:password@localhost:27017/docflow-360?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Health Check
HEALTH_PORT=3002

# OCR Provider (AZURE_DOCUMENT_INTELLIGENCE, GOOGLE_VISION, AWS_TEXTRACT, MOCK)
OCR_PROVIDER=MOCK

# Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# LLM Provider (AZURE_OPENAI, OPENAI, MOCK)
LLM_PROVIDER=MOCK

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=

# Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
BLOB_CONTAINER_RAW=raw-emails
BLOB_CONTAINER_NORMALIZED=normalized-docs

# Worker Configuration
WORKER_CONCURRENCY=5
NODE_ENV=development

