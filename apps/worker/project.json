{
  "name": "worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/worker",
  "projectType": "application",
  "tags": [
    "scope:backend",
    "type:worker"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc",
        "cwd": "apps/worker"
      },
      "outputs": [
        "{projectRoot}/dist"
      ]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon --exec ts-node index.ts",
        "cwd": "apps/worker"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/index.js",
        "cwd": "apps/worker"
      },
      "dependsOn": [
        "build"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Linting not configured yet' && exit 0",
        "cwd": "apps/worker"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No tests configured yet' && exit 0",
        "cwd": "apps/worker"
      }
    }
  }
}
