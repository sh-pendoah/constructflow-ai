# Scheduler Service Environment Variables

# MongoDB
MONGO_URI=mongodb://admin:password@localhost:27017/worklighter?authSource=admin

# Health Check
HEALTH_PORT=3003

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@worklight.com

# Schedule Configuration
COMPLIANCE_CHECK_CRON=0 9 * * *
SUMMARY_EMAIL_CRON=0 8 * * 1
QUEUE_HEALTH_CRON=*/15 * * * *

# Alert Configuration
ALERT_DAYS_BEFORE=[30,15,7,0]
ALERT_RECIPIENTS=admin@example.com

NODE_ENV=development
